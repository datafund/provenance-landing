  <style>
    .hero-gradient-container {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100vh;
      z-index: 0;
      pointer-events: none;
      opacity: 0.7;
    }

    #gradient-canvas {
      width: 100%;
      height: 100%;
    }

    /* Fade out gradient at bottom of hero */
    .hero-gradient-container {
      mask-image: linear-gradient(to bottom, black 0%, black 50%, transparent 100%);
      -webkit-mask-image: linear-gradient(to bottom, black 0%, black 50%, transparent 100%);
    }
  </style>

  <script>
    // Code snippet tab switching
    document.querySelectorAll('.code-tab').forEach(tab => {
      tab.addEventListener('click', () => {
        const target = (tab as HTMLElement).dataset.tab;
        // Update tabs
        document.querySelectorAll('.code-tab').forEach(t => {
          t.classList.remove('active', 'border-blue-500');
          t.classList.add('border-transparent');
        });
        tab.classList.add('active', 'border-blue-500');
        tab.classList.remove('border-transparent');
        // Update panels
        document.querySelectorAll('.code-panel').forEach(p => {
          if ((p as HTMLElement).dataset.panel === target) {
            p.classList.remove('hidden');
          } else {
            p.classList.add('hidden');
          }
        });
      });
    });

    // Animated gradient using Canvas 2D
    const canvas = document.getElementById('gradient-canvas');
    if (canvas) {
      const ctx = (canvas as HTMLCanvasElement).getContext('2d');
      let time = 0;
      let animationId: number;

      function resize() {
        canvas.width = window.innerWidth;
        canvas.height = window.innerHeight;
      }

      function draw() {
        time += 0.003; // Slightly faster animation

        const w = canvas.width;
        const h = canvas.height;

        // Create gradient
        const gradient = ctx.createRadialGradient(
          w * (0.25 + Math.sin(time) * 0.15),
          h * (0.25 + Math.cos(time * 0.7) * 0.15),
          0,
          w * 0.5,
          h * 0.5,
          w * 0.9
        );

        // Stronger blue tones - matching Datafund blue
        const alpha1 = 0.25 + Math.sin(time * 0.5) * 0.08;
        const alpha2 = 0.18 + Math.cos(time * 0.3) * 0.06;

        gradient.addColorStop(0, `rgba(0, 0, 255, ${alpha1})`);
        gradient.addColorStop(0.4, `rgba(59, 130, 246, ${alpha2})`);
        gradient.addColorStop(1, 'rgba(255, 255, 255, 0)');

        ctx.fillStyle = 'white';
        ctx.fillRect(0, 0, w, h);

        ctx.fillStyle = gradient;
        ctx.fillRect(0, 0, w, h);

        // Second gradient blob
        const gradient2 = ctx.createRadialGradient(
          w * (0.75 + Math.cos(time * 0.8) * 0.15),
          h * (0.5 + Math.sin(time * 0.6) * 0.15),
          0,
          w * 0.6,
          h * 0.5,
          w * 0.7
        );

        const alpha3 = 0.15 + Math.sin(time * 0.4) * 0.05;
        gradient2.addColorStop(0, `rgba(99, 102, 241, ${alpha3})`);
        gradient2.addColorStop(0.5, `rgba(139, 92, 246, ${0.1})`);
        gradient2.addColorStop(1, 'rgba(255, 255, 255, 0)');

        ctx.fillStyle = gradient2;
        ctx.fillRect(0, 0, w, h);

        // Third gradient blob for more depth
        const gradient3 = ctx.createRadialGradient(
          w * (0.5 + Math.sin(time * 0.9) * 0.2),
          h * (0.7 + Math.cos(time * 0.5) * 0.1),
          0,
          w * 0.5,
          h * 0.6,
          w * 0.5
        );

        const alpha4 = 0.12 + Math.cos(time * 0.6) * 0.04;
        gradient3.addColorStop(0, `rgba(0, 0, 255, ${alpha4})`);
        gradient3.addColorStop(0.6, `rgba(59, 130, 246, ${0.06})`);
        gradient3.addColorStop(1, 'rgba(255, 255, 255, 0)');

        ctx.fillStyle = gradient3;
        ctx.fillRect(0, 0, w, h);

        animationId = requestAnimationFrame(draw);
      }

      resize();
      window.addEventListener('resize', resize);
      draw();

      // Cleanup on page unload
      window.addEventListener('beforeunload', () => {
        cancelAnimationFrame(animationId);
      });
    }
  </script>
